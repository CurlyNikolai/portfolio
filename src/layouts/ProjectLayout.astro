---
import BaseLayout from './BaseLayout.astro';
import { BASE_PATH } from '../config';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    tags: string[];
    domain: string;
    github?: string;
    demo?: string;
    book?: string;
    steam?: string;
    urls?: Array<{ url: string; name: string }>;
  };
}

const { frontmatter } = Astro.props;

const domainColors: Record<string, string> = {
  "Physics": 'accent1',
  "Game Development": 'accent2',
  "Space": 'accent3',
};
const colorClass = domainColors[frontmatter.domain] ?? '';
---

<BaseLayout title={`${frontmatter.title} — Emil`} description={frontmatter.description}>
  <div class="project-hero container">
    <a href=`${BASE_PATH}/#projects` class="back-link">← Back to projects</a>

    <div class="project-meta">
      <span class={`tag ${colorClass}`}>{frontmatter.domain}</span>
      <span class="project-date">{frontmatter.date}</span>
    </div>

    <h1 class="project-title">{frontmatter.title}</h1>
    <p class="project-description">{frontmatter.description}</p>

    <div class="project-links">
      {frontmatter.github && (
        <a href={frontmatter.github} class="btn btn-ghost" target="_blank">
          GitHub ↗
        </a>
      )}
      {frontmatter.demo && (
        <a href={frontmatter.demo} class="btn btn-primary" target="_blank">
          Live Demo ↗
        </a>
      )}
      {frontmatter.book && (
        <a href={frontmatter.book} class="btn btn-primary" target="_blank">
          Book ↗
        </a>
      )}
      {frontmatter.steam && (
        <a href={frontmatter.steam} class="btn btn-primary" target="_blank">
          Steam page ↗
        </a>
      )}
      {frontmatter.urls && (
        <>
          {frontmatter.urls.map(link => (
            <a href={link.url} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              {link.name} ↗
            </a>
          ))}
        </>
)}
    </div>

    <div class="project-tags">
      {frontmatter.tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  </div>

  <div class="project-body container">
    <div class="prose">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
.project-hero {
  padding-top: 8rem;
  padding-bottom: 3rem;
  border-bottom: 1px solid var(--border);
}

.back-link {
  font-family: var(--mono);
  font-size: 0.8rem;
  color: var(--muted);
  display: inline-block;
  margin-bottom: 2rem;
  transition: color 0.2s;
}
.back-link:hover { color: var(--accent1); text-decoration: none; }

.project-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.project-date {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--muted);
}

.project-title {
  font-size: clamp(2.2rem, 6vw, 4rem);
  font-weight: 800;
  margin-bottom: 1rem;
}

.project-description {
  font-size: 1.15rem;
  color: var(--muted);
  max-width: 640px;
  margin-bottom: 2rem;
  line-height: 1.7;
}

.project-links {
  display: flex;
  gap: 1rem;
  margin-bottom: 2rem;
}

.project-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.project-body {
  padding-top: 3rem;
  padding-bottom: 6rem;
}

.prose {
  max-width: 720px;
}

.prose :global(h2) {
  font-size: 1.6rem;
  margin: 2.5rem 0 1rem;
  color: var(--heading);
}

.prose :global(h3) {
  font-size: 1.2rem;
  margin: 2rem 0 0.75rem;
  color: var(--accent1);
  font-family: var(--mono);
  font-weight: 400;
}

.prose :global(p) {
  margin-bottom: 1.25rem;
  color: var(--text);
  line-height: 1.8;
}

.prose :global(ul), .prose :global(ol) {
  margin: 1rem 0 1.5rem 1.5rem;
  color: var(--text);
  line-height: 1.8;
}

.prose :global(li) { margin-bottom: 0.5rem; }

.prose :global(code) {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 0.15rem 0.4rem;
  border-radius: 3px;
  color: var(--accent1);
}

.prose :global(pre) {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.5rem;
  overflow-x: auto;
  margin: 1.5rem 0;
}

.prose :global(pre code) {
  background: none;
  border: none;
  padding: 0;
  color: var(--text);
}

.prose :global(blockquote) {
  border-left: 3px solid var(--accent1);
  padding-left: 1.25rem;
  margin: 1.5rem 0;
  color: var(--muted);
  font-style: italic;
}

.prose :global(img) {
  width: 100%;
  border-radius: 8px;
  border: 1px solid var(--border);
  margin: 1.5rem 0;
  height: auto;
}
</style>
